@page
@model RoomBooking.Pages.ProfileModel
<div class="profile-form">
    <h2>Профиль пользователя</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
            <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    <div class="form-group">
        <label>Ваш логин:</label>
        <input asp-for="Login" class="form-control" readonly />
    </div>

    <!-- Кнопки для работы с комнатами в одну линию -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Управление комнатами</h5>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-area="" asp-page="/RoomControl/AddRoom">Добавить комнату</a>
                <a class="btn btn-outline-danger" asp-area="" asp-page="/RoomControl/RemoveRoom">Удалить комнату</a>

                <form method="post" asp-page-handler="RedactRoom" class="d-flex gap-2 align-items-center">
                    <div class="form-group mb-0" style="min-width: 150px;">
                        <input asp-for="RoomIdRedact" class="form-control" placeholder="ID комнаты" />
                    </div>
                    <button type="submit" class="btn btn-outline-warning">Редактировать комнату</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Кнопки для работы с бронями в одну линию -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Управление бронированиями</h5>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-area="" asp-page="/BookingControls/MakeBooking">Сделать бронь</a>
                <a class="btn btn-primary" asp-area="" asp-page="/BookingControls/CancelBooking">Отменить бронь</a>
            </div>
        </div>
    </div>

    <table class="table table-striped">
        <caption>Ваши комнаты</caption>
        <thead>
            <tr>
                <th>ID комнаты</th>
                <th>Описание</th>
                <th>Адрес</th>
                <th>Цена аренды за час</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.UsersRooms)
            {
                    <tr>
                        <td>@room.RoomId</td>
                        <td>@room.Description</td>
                        <td>@room.Address</td>
                        <td>@room.PricePerHour</td>
                    </tr>
            }
        </tbody>
    </table>

    <table class="table table-striped">
        <caption>Ваши брони</caption>
        <thead>
            <tr>
                <th>ID брони</th>
                <th>ID комнаты</th>
                <th>Время начала брони</th>
                <th>Время конца брони</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.UserBookings)
            {
                    <tr>
                        <td>@booking.BookingId</td>
                        <td>@booking.RoomId</td>
                        <td>@booking.StartTime</td>
                        <td>@booking.EndTime</td>
                    </tr>
            }
        </tbody>
    </table>

    <table class="table table-striped">
        <caption>Брони ваших комнат</caption>
        <thead>
            <tr>
                <th>ID брони</th>
                <th>ID комнаты</th>
                <th>Время начала брони</th>
                <th>Время конца брони</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.BookingsOfAUsersRoom)
            {
                    <tr>
                        <td>@booking.BookingId</td>
                        <td>@booking.RoomId</td>
                        <td>@booking.StartTime</td>
                        <td>@booking.EndTime</td>
                    </tr>
            }
        </tbody>
    </table>
</div>

<style>
    /* Дополнительные стили для улучшения отображения */
    .gap-2 {
        gap: 0.5rem;
    }

    .d-flex .form-group {
        margin-bottom: 0;
    }

    @@media (max-width: 768px) {
        .d-flex.flex-wrap {
            flex-direction: column;
        }

        .d-flex.flex-wrap .form-group {
            width: 100%;
            min-width: 100% !important;
        }

        .d-flex.flex-wrap .btn {
            width: 100%;
        }
    }
</style>