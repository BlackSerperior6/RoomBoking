@page
@model RoomBooking.Pages.ProfileModel
<div class="profile-form">
    <h2>Профиль пользователя</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
            <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    <div class="form-group">
        <label>Ваш логин:</label>
        <h3>@Model.Login</h3>
    </div>

    <!-- Кнопки для работы с комнатами -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Управление комнатами</h5>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <a class="btn btn-primary" asp-area="" asp-page="/RoomControl/AddRoom">Добавить комнату</a>
                <a class="btn btn-outline-danger" asp-area="" asp-page="/RoomControl/RemoveRoom">Удалить комнату</a>
                <button type="submit" form="redactRoomForm" class="btn btn-outline-warning">Редактировать комнату</button>
            </div>

            <!-- Форма с ID комнаты на отдельной строке -->
            <form id="redactRoomForm" method="post" asp-page-handler="RedactRoom" class="mt-2">
                <div class="form-group">
                    <label asp-for="RoomIdRedact">ID комнаты для редактирования:</label>
                    <div class="row">
                        <div class="col-md-4">
                            <input asp-for="RoomIdRedact" type="number" step="1" min="1" max="2147483647" class="form-control" placeholder="Введите ID комнаты" />
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Кнопки для работы с бронями -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Управление бронированиями</h5>
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-area="" asp-page="/BookingControls/MakeBooking">Сделать бронь</a>
                <a class="btn btn-primary" asp-area="" asp-page="/BookingControls/CancelBooking">Отменить бронь</a>
                <a class="btn btn-primary" asp-area="" asp-page="/SeeAllRooms">Просмотр всех комнат</a>
            </div>
        </div>
    </div>

    <table class="table table-striped">
        <h3>Ваши комнаты</h3>
        <thead>
            <tr>
                <th>ID комнаты</th>
                <th>Описание</th>
                <th>Адрес</th>
                <th>Цена аренды за час</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.UsersRooms)
            {
                    <tr>
                        <td>@room.RoomId</td>
                        <td>@room.Description</td>
                        <td>@room.Address</td>
                        <td>@room.PricePerHour</td>
                    </tr>
            }
        </tbody>
    </table>

    <table class="table table-striped">
        <h3>Ваши брони</h3>
        <thead>
            <tr>
                <th>ID брони</th>
                <th>ID комнаты</th>
                <th>Время начала брони</th>
                <th>Время конца брони</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model.UserBookings)
            {
                    <tr>
                        <td>@booking.BookingId</td>
                        <td>@booking.RoomId</td>
                        <td>@booking.StartTime</td>
                        <td>@booking.EndTime</td>
                    </tr>
            }
        </tbody>
    </table>
</div>

<style>
    /* Дополнительные стили для улучшения отображения */
    .gap-2 {
        gap: 0.5rem;
    }

    .form-group label {
        font-weight: 500;
        margin-bottom: 0.25rem;
    }

    @@media (max-width: 768px) {
        .d-flex.flex-wrap {
            flex-direction: column;
        }

        .d-flex.flex-wrap .btn {
            width: 100%;
        }

        .col-md-4 {
            width: 100%;
        }
    }
</style>