@page
@model RoomBooking.Pages.BookingControls.MakeBookingModel
<div class="makeBooking-form">
    <h2>Бронирование</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label>ID комнаты</label>
            <input asp-for="RoomId" class="form-control" />
        </div>
        <div class="form-group">
            <label>Время начала</label>
            <input asp-for="StartDate" type="datetime-local" class="form-control" />
        </div>
        <div class="form-group">
            <label>Время конца</label>
            <input asp-for="EndDate" type="datetime-local" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Забронировать</button>
    </form>
</div>