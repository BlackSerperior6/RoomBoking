@page
@model RoomBooking.Pages.RoomControl.RedactRoomModel
<div class="redactRoom-form">
    <h2>Редактирование коматы</h2>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="form-group">
            <label>Описание</label>
            <input asp-for="Description" class="form-control" />
        </div>
        <div class="form-group">
            <label>Адрес</label>
            <input asp-for="Address" class="form-control" />
        </div>
        <div class="form-group">
            <label>Цена за час</label>
            <input asp-for="PricePerHour" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Закончить редактирование</button>
    </form>
</div>